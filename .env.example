ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-5

RUNWAYML_API_SECRET=your-runway-api-secret
RUNWAY_MODEL=gen4.5

ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Optional: TV-loglines RAG inspiration step (Pinecone). If PINECONE_API_KEY is
# left blank, the film pipeline just skips this step and uses your raw idea as-is.
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=tv-loglines
LOGLINE_EMBEDDING_MODEL=multilingual-e5-large
LOGLINE_TOP_K=10
LOGLINE_BATCH_SIZE=96
LOGLINE_DATA_DIR=./tv_loglines_dataset

HOST=0.0.0.0
PORT=8000
STORAGE_DIR=./storage
